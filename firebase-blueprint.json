{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "balance": { "type": "number", "description": "Current available cash balance" }
      },
      "required": ["uid", "email", "balance"]
    },
    "TeamStock": {
      "title": "NFL Team Stock",
      "description": "Market data for a specific NFL team",
      "type": "object",
      "properties": {
        "symbol": { "type": "string", "description": "Team abbreviation e.g., MIN" },
        "name": { "type": "string" },
        "marketCap": { "type": "number" },
        "price": { "type": "number" },
        "prevPrice": { "type": "number" },
        "change": { "type": "number" },
        "changePercent": { "type": "number" }
      },
      "required": ["symbol", "name", "price"]
    },
    "PortfolioItem": {
      "title": "User Portfolio Item",
      "description": "Shares of a team stock owned by a user",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "shares": { "type": "number" },
        "avgPrice": { "type": "number" }
      },
      "required": ["teamId", "shares", "avgPrice"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Buy, sell, deposit, or withdrawal event",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell", "deposit", "withdraw"] },
        "assetId": { "type": "string" },
        "amount": { "type": "number" },
        "shares": { "type": "number" },
        "price": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "timestamp"]
    },
    "FanCardRequest": {
      "title": "Fan Card Inquiry",
      "description": "Request for a physical or premium fan card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "teamId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "responded", "fulfilled"] },
        "contactMethod": { "type": "string" },
        "message": { "type": "string" },
        "replies": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "teamId", "status"]
    },
    "StoreOrder": {
      "title": "Store Purchase",
      "description": "Order for tickets or jerseys",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "itemType": { "type": "string", "enum": ["ticket", "jersey", "membership"] },
        "itemName": { "type": "string" },
        "price": { "type": "number" },
        "teamId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "itemType", "price", "timestamp"]
    },
    "Experience": {
      "title": "NFL Experience Product",
      "description": "Premium Tours, Player Meet & Greets, and Luxury Packages",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["stadium_tour", "meet_greet", "private_tour"] },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "teamId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "player": { "type": "string" },
        "location": { "type": "string" },
        "dates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeSlots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" }
      },
      "required": ["title", "type", "category", "price", "teamId"]
    },
    "ExperienceBooking": {
      "title": "Experience Booking",
      "description": "User reservation for an NFL Experience",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "experienceId": { "type": "string" },
        "experienceTitle": { "type": "string" },
        "experienceType": { "type": "string" },
        "date": { "type": "string" },
        "timeSlot": { "type": "string" },
        "guestsCount": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "completed", "cancelled"] },
        "qrCode": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "experienceId", "experienceTitle", "date", "timeSlot", "guestsCount", "totalPrice", "status"]
    },
    "PromoBanner": {
      "title": "Promotional Active Banner",
      "description": "Rotating advertisement configurations for landing page sliders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "imageUrl": { "type": "string" },
        "linkTab": { "type": "string" },
        "targetId": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "title", "imageUrl", "isActive"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/portfolio/{teamId}": {
      "schema": "PortfolioItem",
      "description": "User's current stock positions"
    },
    "users/{userId}/transactions/{txId}": {
      "schema": "Transaction",
      "description": "User's transaction history"
    },
    "teams/{teamId}": {
      "schema": "TeamStock",
      "description": "Live market data for NFL teams"
    },
    "fan_card_requests/{requestId}": {
      "schema": "FanCardRequest",
      "description": "User inquiries for fan cards"
    },
    "store_orders/{orderId}": {
      "schema": "StoreOrder",
      "description": "Global log of store purchases"
    },
    "global_transactions/{txId}": {
      "schema": "Transaction",
      "description": "Global log of all financial events for admin auditing"
    },
    "experiences/{experienceId}": {
      "schema": "Experience",
      "description": "Global experiences and tours"
    },
    "bookings/{bookingId}": {
      "schema": "ExperienceBooking",
      "description": "User experience bookings and tickets"
    },
    "promo_banners/{bannerId}": {
      "schema": "PromoBanner",
      "description": "Admin promotional banners"
    },
    "admins/{userId}": {
      "schema": {
        "title": "Admin Record",
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "role": { "type": "string" }
        },
        "required": ["email"]
      },
      "description": "Authorized administrators"
    }
  }
}
